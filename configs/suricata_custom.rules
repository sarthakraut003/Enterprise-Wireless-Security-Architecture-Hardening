# Detection for Wireless Deauthentication Attacks
alert (msg:"WIRELESS Deauth Attack Detected"; dot11.type == 0x00 && dot11.subtype == 0x0c; sid:1000001; rev:1;)

# Detection for Unauthorized Bluetooth Reconnaissance
alert (msg:"BLUETOOTH Unauthorized Scan Detected"; hci.event == 0x01; sid:1000002; rev:1;)
